{
  "name": "location-sharing-api",
  "version": "1.0.0",
  "description": "Location Sharing API - AWS SAM backend for real-time location sharing",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "deployDev": "sam build && sam deploy"
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.991.0",
    "@aws-sdk/client-ssm": "^3.993.0",
    "@aws-sdk/lib-dynamodb": "^3.991.0",
    "axios": "^1.13.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^25.2.3",
    "esbuild": "^0.24.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}
